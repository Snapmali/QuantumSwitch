# Quantum Switch 配置文件
# 复制此文件并根据实际路径修改

# Mods 目录路径，不填写则自动从注册表中读取
#GAME_MODS_DIRECTORY='C:\Program Files (x86)\Steam\steamapps\common\Hatsune Miku Project DIVA Mega Mix Plus\mods'

# 调试模式 (true/false)
DEBUG=false

# 服务器主机和端口
HOST=127.0.0.1
PORT=8000

# 游戏进程名称 (通常不需要修改)
GAME_PROCESS_NAME=DivaMegaMix.exe
